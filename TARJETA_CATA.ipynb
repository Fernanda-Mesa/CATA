        "def generar_cara_info(industria, problema, ancho=750, alto=1050):\n",
        "    \"\"\"Genera la cara frontal con la información de la empresa y la solución.\"\"\"\n",
        "    color_grisb_fondo = (245, 245, 245)  # Gris muy claro casi blanco\n",
        "    color_texto_oscuro = (30, 30, 30)\n",
        "    color_morado = (102, 36, 131) # Color solicitado #662483\n",
        "\n",
        "    tarjeta = Image.new('RGB', (ancho, alto), color=color_grisb_fondo)\n",
        "    draw = ImageDraw.Draw(tarjeta)\n",
        "\n",
        "    fuente_titulo = obtener_fuente(45)\n",
        "    fuente_subtitulo = obtener_fuente(35)\n",
        "    fuente_texto = obtener_fuente(28)\n",
        "\n",
        "    # Borde morado para combinar con la otra cara\n",
        "    draw.rectangle([20, 20, ancho-20, alto-20], outline=color_morado, width=8)\n",
        "\n",
        "    # 1. INDUSTRIA\n",
        "    draw.text((60, 100), \"SECTOR INDUSTRIAL:\", fill=color_morado, font=fuente_titulo)\n",
        "    draw.text((60, 160), industria, fill=color_texto_oscuro, font=fuente_subtitulo)\n",
        "    draw.line([(60, 220), (ancho-60, 220)], fill=color_morado, width=3)\n",
        "\n",
        "    # 2. PROBLEMÁTICA\n",
        "    draw.text((60, 280), \"EL PROBLEMA:\", fill=color_morado, font=fuente_titulo)\n",
        "\n",
        "    y_pos = 350\n",
        "    lineas_problema = textwrap.wrap(problema, width=42)\n",
        "    for linea in lineas_problema:\n",
        "        draw.text((60, y_pos), linea, fill=color_texto_oscuro, font=fuente_texto)\n",
        "        y_pos += 45\n",
        "\n",
        "    return tarjeta"
      ],
      "metadata": {
