        "def generar_cara_solucion(solucion, ancho=750, alto=1050):\n",
        "    \"\"\"Genera la carta número 2: Solución Astronómica.\"\"\"\n",
        "    color_grisb_fondo = (245, 245, 245)\n",
        "    color_texto_oscuro = (30, 30, 30)\n",
        "    color_morado = (106, 27, 154)\n",
        "\n",
        "    tarjeta = Image.new('RGB', (ancho, alto), color=color_grisb_fondo)\n",
        "    draw = ImageDraw.Draw(tarjeta)\n",
        "\n",
        "    fuente_titulo = obtener_fuente(45)\n",
        "    fuente_texto = obtener_fuente(28)\n",
        "\n",
        "    # Borde morado\n",
        "    draw.rectangle([20, 20, ancho-20, alto-20], outline=color_morado, width=8)\n",
        "\n",
        "    # TÍTULO DE LA SOLUCIÓN\n",
        "    draw.text((ancho//2, 150), \"SOLUCIÓN DESDE LA\\n ASTRONOMÍA\",\n",
        "              fill=color_morado, anchor=\"mm\", align=\"center\", font=fuente_titulo)\n",
        "    draw.line([(100, 220), (ancho-100, 220)], fill=color_morado, width=3)\n",
        "\n",
        "    # TEXTO DE LA SOLUCIÓN\n",
        "    y_pos = 280\n",
        "    lineas_solucion = textwrap.wrap(solucion, width=42)\n",
        "    for linea in lineas_solucion:\n",
        "        # Centramos el texto de la solución para que se vea más elegante en su propia carta\n",
        "        draw.text((ancho//2, y_pos), linea, fill=color_texto_oscuro,\n",
        "                  anchor=\"mm\", align=\"center\", font=fuente_texto)\n",
        "        y_pos += 45\n",
        "\n",
        "    return tarjeta"
      ],
