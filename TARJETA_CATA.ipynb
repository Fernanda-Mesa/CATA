        "def crear_primer_set():\n",
        "    \"\"\"Función principal que une las piezas y genera las imágenes.\"\"\"\n",
        "    # Datos de prueba para nuestra primera tarjeta\n",
        "    industria_ej = \"Agricultura de Precisión\"\n",
        "    problema_ej = (\"Monitorear la salud de cientos de hectáreas de cultivos \"\n",
        "                        \"y detectar estrés hídrico o plagas de forma temprana y eficiente.\")\n",
        "    solucion_ej = (\"Utilización de algoritmos de procesamiento de imágenes multiespectrales, \"\n",
        "                        \"originalmente desarrollados para limpiar imágenes de galaxias lejanas, \"\n",
        "                        \"aplicados a fotografías de satélites o drones para analizar los cultivos.\")\n",
        "\n",
        "    # Generar las tres caras\n",
        "    cara_logo = generar_cara_logo()\n",
        "    cara_info = generar_cara_info(industria_ej, problema_ej)\n",
        "    cara_solucion = generar_cara_solucion(solucion_ej)\n",
        "\n",
        "    # Guardar los archivos\n",
        "    cara_logo.save(\"FRONT_Logo.png\")\n",
        "    cara_info.save(\"FRONT_Info.png\")\n",
        "    cara_solucion.save(\"FRONT_Solucion.png\")\n",
        "\n",
        "    # Mostrar en pantalla\n",
        "    fig, axes = plt.subplots(1, 3, figsize=(15, 7))\n",
        "\n",
        "    axes[0].imshow(cara_logo)\n",
        "    axes[0].axis('off')\n",
        "    axes[0].set_title('Cara Posterior (Logo)')\n",
        "\n",
        "    axes[1].imshow(cara_info)\n",
        "    axes[1].axis('off')\n",
        "    axes[1].set_title('Cara Frontal (Información)')\n",
        "\n",
        "    axes[2].imshow(cara_solucion)\n",
        "    axes[2].axis('off')\n",
        "    axes[2].set_title('Cara Frontal (Solución)')\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    crear_primer_set()\n"
      ],
