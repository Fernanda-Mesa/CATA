    {
      "cell_type": "code",
      "source": [
        "def generar_cara_logo(ancho=750, alto=1050):\n",
        "    \"\"\"Genera la cara de la tarjeta con fondo morado y el logo centrado.\"\"\"\n",
        "    color_morado = (102, 36, 131)  # Color solicitado #662483\n",
        "    tarjeta = Image.new('RGB', (ancho, alto), color=color_morado)\n",
        "\n",
        "    # Intentar cargar y centrar el logo\n",
        "    ruta_fondo = \"Background_CATA.png\"\n",
        "    ruta_logo = \"Logo_CATA_BLANCO.png\"\n",
        "\n",
        "    # 1. CARGAR EL FONDO DEL UNIVERSO\n",
        "    try:\n",
        "        fondo_original = Image.open(ruta_fondo).convert(\"RGB\")\n",
        "        tarjeta = ImageOps.fit(fondo_original, (ancho, alto), method=Image.Resampling.LANCZOS)\n",
        "    except FileNotFoundError:\n",
        "        tarjeta = Image.new('RGB', (ancho, alto), color=(106, 27, 154))\n",
        "\n",
        "    # 2. CARGAR EL LOGO SOBRE EL FONDO\n",
        "    try:\n",
        "        logo = Image.open(ruta_logo).convert(\"RGBA\")\n",
        "        logo.thumbnail((400, 400))  # Tamaño del logo más grande para esta cara\n",
        "        logo_x = (ancho - logo.width) // 2\n",
        "        logo_y = (alto - logo.height) // 2\n",
        "        tarjeta.paste(logo, (logo_x, logo_y), logo)\n",
        "    except FileNotFoundError:\n",
        "        print(f\"Aviso: No se encontró el logo en {ruta_logo}\")\n",
        "        draw = ImageDraw.Draw(tarjeta)\n",
        "        fuente = obtener_fuente(50)\n",
        "        draw.text((ancho//2, alto//2), \"LOGO CATA\\n(Falta imagen)\",\n",
        "                  fill=(255,255,255), anchor=\"mm\", align=\"center\", font=fuente)\n",
        "\n",
        "    return tarjeta"
      ],
      "metadata": {
        "id": "2j90v9Spiab0"
      },
      "execution_count": 50,
      "outputs": []
    },
