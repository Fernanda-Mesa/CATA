        "def obtener_fuente(tamano):\n",
        "    \"\"\"Descarga la fuente Roboto si no existe y la devuelve en el tamaño solicitado.\"\"\"\n",
        "    font_url = (\n",
        "        \"https://github.com/googlefonts/roboto/raw/main/\"\n",
        "        \"src/hinted/Roboto-Bold.ttf\"\n",
        "    )\n",
        "    font_path = \"Roboto-Bold.ttf\"\n",
        "\n",
        "    if not os.path.exists(font_path):\n",
        "        print(\"Descargando fuente Roboto...\")\n",
        "        urllib.request.urlretrieve(font_url, font_path)\n",
        "\n",
        "    return ImageFont.truetype(font_path, tamano)"
      ],
