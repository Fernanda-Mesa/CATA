        "import os\n",
        "import textwrap\n",
        "import urllib.request\n",
        "import matplotlib.pyplot as plt\n",
        "from PIL import Image, ImageDraw, ImageFont\n",
        "\n",
        "\n",
        "def obtener_fuente():\n",
        "    # URL dividida en dos líneas para evitar el error de \"línea muy larga\" (E501)\n",
        "    font_url = (\n",
        "        \"https://github.com/googlefonts/roboto/\"\n",
        "        \"raw/main/src/hinted/Roboto-Bold.ttf\"\n",
        "    )\n",
        "    font_path = \"Roboto-Bold.ttf\"\n",
        "\n",
        "    if not os.path.exists(font_path):\n",
        "        print(\"Descargando fuente Roboto para los textos...\")\n",
        "        urllib.request.urlretrieve(font_url, font_path)\n",
        "\n",
        "    return font_path\n",
        "\n",
        "\n",
        "def crear_carta(titulo, subtitulo, texto, color_fondo, color_texto):\n",
        "    \"\"\"Genera la cara frontal de una carta (Problema o Solución).\"\"\"\n",
        "    ancho, alto = 750, 1050\n",
        "    carta = Image.new('RGB', (ancho, alto), color=color_fondo)\n",
        "    draw = ImageDraw.Draw(carta)\n",
        "\n",
        "    font_path = obtener_fuente()\n",
        "    font_titulo = ImageFont.truetype(font_path, 50)\n",
        "    font_texto = ImageFont.truetype(font_path, 35)\n",
        "\n",
        "    # Dibujar borde\n",
        "    draw.rectangle(\n",
        "        [30, 30, ancho-30, alto-30],\n",
        "        outline=color_texto,\n",
        "        width=10\n",
        "    )\n",
        "\n",
        "    # Título principal (Ej: PROBLEMÁTICA o SOLUCIÓN)\n",
        "    draw.text(\n",
        "        (ancho // 2, 120), titulo, fill=color_texto,\n",
        "        anchor=\"mm\", align=\"center\", font=font_titulo\n",
        "    )\n",
        "    draw.line([(100, 170), (ancho-100, 170)], fill=color_texto, width=5)\n",
        "\n",
        "    # Subtítulo (Ej: Industria Minera)\n",
        "    if subtitulo:\n",
        "        draw.text(\n",
        "            (ancho // 2, 250), subtitulo.upper(), fill=color_texto,\n",
        "            anchor=\"mm\", align=\"center\", font=font_titulo\n",
        "        )\n",
        "\n",
        "    # Texto descriptivo (Ajustado a múltiples líneas)\n",
        "    lineas = textwrap.wrap(texto, width=32)\n",
        "    y_pos = 380\n",
        "    for linea in lineas:\n",
        "        draw.text(\n",
        "            (ancho // 2, y_pos), linea, fill=color_texto,\n",
        "            anchor=\"mm\", align=\"center\", font=font_texto\n",
        "        )\n",
        "        y_pos += 45\n",
        "\n",
        "    return carta\n",
        "\n",
        "\n",
        "def crear_dorso(ruta_logo=\"logo_cata.png\"):\n",
        "    \"\"\"Genera el dorso de la carta con el logo del CATA.\"\"\"\n",
        "    ancho, alto = 750, 1050\n",
        "    color_fondo = (10, 25, 50)  # Azul oscuro\n",
        "    dorso = Image.new('RGB', (ancho, alto), color=color_fondo)\n",
        "    draw = ImageDraw.Draw(dorso)\n",
        "\n",
        "    # Borde del dorso\n",
        "    draw.rectangle(\n",
        "        [30, 30, ancho-30, alto-30],\n",
        "        outline=(0, 150, 255),\n",
        "        width=10\n",
        "    )\n",
        "\n",
        "    try:\n",
        "        # Intenta abrir el logo y pegarlo en el centro\n",
        "        logo = Image.open(ruta_logo).convert(\"RGBA\")\n",
        "        logo.thumbnail((400, 400))  # Ajusta el tamaño máximo del logo\n",
        "        logo_x = (ancho - logo.width) // 2\n",
        "        logo_y = (alto - logo.height) // 2\n",
        "        dorso.paste(logo, (logo_x, logo_y), logo)\n",
        "    except FileNotFoundError:\n",
        "        # Si no encuentra el logo, dibuja un texto de reemplazo\n",
        "        font_path = obtener_fuente()\n",
        "        font_logo = ImageFont.truetype(font_path, 50)\n",
        "        draw.text(\n",
        "            (ancho // 2, alto // 2), \"LOGO CATA\\n(Falta imagen)\",\n",
        "            fill=(255, 255, 255), anchor=\"mm\", align=\"center\", font=font_logo\n",
        "        )\n",
        "\n",
        "    return dorso\n",
        "\n",
        "\n",
        "def generar_juego_completo():\n",
        "    \"\"\"Función principal que orquesta la creación de las cartas.\"\"\"\n",
        "\n",
        "    # 1. Crear Carta de Problemática\n",
        "    carta_problema = crear_carta(\n",
        "        titulo=\"PROBLEMÁTICA\",\n",
        "        subtitulo=\"Industria Minera\",\n",
        "        texto=\"Fallas imprevistas en la maquinaria pesada generan largos \"\n",
        "              \"tiempos de inactividad y altos costos operativos.\",\n",
        "        color_fondo=(245, 245, 245),  # Gris muy claro\n",
        "        color_texto=(200, 30, 30)     # Rojo para el problema\n",
        "    )\n",
        "\n",
        "    # 2. Crear Carta de Solución\n",
        "    carta_solucion = crear_carta(\n",
        "        titulo=\"SOLUCIÓN\",\n",
        "        subtitulo=\"Mantenimiento Predictivo\",\n",
        "        texto=\"Implementar modelos de Machine Learning usando datos de \"\n",
        "              \"sensores para predecir y evitar fallas.\",\n",
        "        color_fondo=(20, 40, 60),     # Azul oscuro\n",
        "        color_texto=(50, 220, 120)    # Verde para la solución\n",
        "    )\n",
        "\n",
        "    # 3. Crear el Dorso\n",
        "    dorso = crear_dorso(\"logo_cata.png\")\n",
        "\n",
        "    # Guardar los archivos\n",
        "    carta_problema.save(\"Carta_1_Problema.png\")\n",
        "    carta_solucion.save(\"Carta_1_Solucion.png\")\n",
        "    dorso.save(\"Carta_Dorso.png\")\n",
        "\n",
        "    # Mostrar en pantalla\n",
        "    fig, axes = plt.subplots(1, 3, figsize=(15, 7))\n",
        "\n",
        "    axes[0].imshow(carta_problema)\n",
        "    axes[0].axis('off')\n",
        "    axes[0].set_title('Carta: Problemática')\n",
        "\n",
        "    axes[1].imshow(carta_solucion)\n",
        "    axes[1].axis('off')\n",
        "    axes[1].set_title('Carta: Solución')\n",
        "\n",
        "    axes[2].imshow(dorso)\n",
        "    axes[2].axis('off')\n",
        "    axes[2].set_title('Dorso (Logo)')\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "# Punto de entrada correcto en Python (evita errores E305)\n",
        "if __name__ == \"__main__\":\n",
        "    generar_juego_completo()"
      ]
